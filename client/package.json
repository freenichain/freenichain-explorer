	"jest": {
		"collectCoverageFrom": [
			"src/**/*.{test,js,jsx}",
			"!src/**/*.{json}",
			"!src/config.js",
			"!src/index.js",
			"!src/**/*/index.js",
			"!src/state/*.js",
			"!src/**/Theme/Theme.js",
			"!src/**/Route/Private.js",
			"!src/state/store.js",
			"!src/setupTests.js",
			"!src/registerServiceWorker.js",
			"!src/services/*.js",
			"!src/components/Main.js",
			"!src/components/Login/Login.js",
			"!src/components/Register/Register.js",
			"!src/components/View/LandingPage.js",
			"!src/state/redux/auth/operations.js"
		],
		"coverageReporters": [
			"json",
			"lcov",
			"text"
		],
		"coverageThreshold": {
			"global": {
				"branches": 0,
				"functions": 0,
				"lines": 0,
				"statements": 0
			},
			"./src/components/": {
				"branches": 0,
				"statements": 0
			}
		},
		"snapshotSerializers": []
	},
	"browserslist": [
		">0.2%",
		"not dead",
		"not ie <= 11",
		"not op_mini all"
	],
	"eslintConfig": {
		"extends": "react-app",
		"overrides": [
			{
				"files": [
					"**/*.js"
				],
				"rules": {
					"indent": "off",
					"import/no-anonymous-default-export": "off"
				}
			}
		]
	},
	"engines": {
		"node": ">=24.0.0"
	}
